<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body
    style="margin: 0; padding: 0; background-color: #f5f5f5; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;">
    <table width="100%" border="0" cellspacing="0" cellpadding="0"
        style="background-color: #f5f5f5; padding: 40px 20px;">
        <tr>
            <td align="center">
                <!-- Main Container -->
                <table width="600" border="0" cellspacing="0" cellpadding="0"
                    style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);">

                    <!-- Header with Gradient -->
                    <tr>
                        <td
                            style="background: linear-gradient(135deg, #f37e20 0%, #ff9f4d 100%); padding: 40px 40px 30px 40px; text-align: center;">
                            <img src="https://69.62.84.25:10017/extalk.png" width="160" height="auto" alt="ExTalk Logo"
                                style="display: block; margin: 0 auto 20px auto;">
                            <h1
                                style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700; letter-spacing: -0.5px;">
                                Password Reset Request</h1>
                        </td>
                    </tr>

                    <!-- Content Section -->
                    <tr>
                        <td style="padding: 40px;">
                            <!-- Greeting -->
                            <p style="margin: 0 0 20px 0; font-size: 16px; color: #333333; line-height: 1.6;">
                                Hello there! 👋
                            </p>

                            <!-- Main Message -->
                            <p style="margin: 0 0 24px 0; font-size: 16px; color: #555555; line-height: 1.6;">
                                We received a request to reset your password for your <strong
                                    style="color: #f37e20;">ExTalk</strong> account.
                            </p>

                            <!-- OTP Box -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin: 30px 0;">
                                <tr>
                                    <td
                                        style="background: linear-gradient(135deg, #fff5f0 0%, #ffe8d9 100%); border: 2px dashed #f37e20; border-radius: 12px; padding: 30px; text-align: center;">
                                        <p
                                            style="margin: 0 0 12px 0; font-size: 14px; color: #666666; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;">
                                            Your One-Time Password
                                        </p>
                                        <p
                                            style="margin: 0; font-size: 42px; color: #f37e20; font-weight: 700; letter-spacing: 12px; font-family: 'Courier New', monospace;">
                                            <%= otp %>
                                        </p>
                                        <p style="margin: 12px 0 0 0; font-size: 13px; color: #888888;">
                                            Valid for <strong>10 minutes</strong>
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Security Notice -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="margin: 24px 0; background-color: #fff8f0; border-left: 4px solid #ff9f4d; border-radius: 8px;">
                                <tr>
                                    <td style="padding: 20px;">
                                        <p
                                            style="margin: 0 0 8px 0; font-size: 14px; color: #d97918; font-weight: 600;">
                                            🔒 Security Notice
                                        </p>
                                        <p style="margin: 0; font-size: 14px; color: #666666; line-height: 1.5;">
                                            • Never share this OTP with anyone<br>
                                            • ExTalk staff will never ask for your OTP<br>
                                            • This code expires in 10 minutes
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Additional Info -->
                            <p style="margin: 24px 0 0 0; font-size: 14px; color: #777777; line-height: 1.6;">
                                If you didn't request this password reset, please ignore this email or contact our
                                support team if you have concerns about your account security.
                            </p>

                            <!-- Divider -->
                            <div
                                style="margin: 30px 0; height: 1px; background: linear-gradient(to right, transparent, #e0e0e0, transparent);">
                            </div>

                            <!-- Signature -->
                            <p style="margin: 0; font-size: 15px; color: #333333; line-height: 1.6;">
                                Best regards,<br>
                                <strong style="color: #f37e20; font-weight: 600;">The ExTalk Team</strong>
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td
                            style="background-color: #fafafa; padding: 30px 40px; text-align: center; border-top: 1px solid #e0e0e0;">
                            <p style="margin: 0 0 8px 0; font-size: 13px; color: #999999;">
                                © 2026 ExTalk. All rights reserved.
                            </p>
                            <p style="margin: 0; font-size: 12px; color: #bbbbbb;">
                                This is an automated email. Please do not reply to this message.
                            </p>
                        </td>
                    </tr>

                </table>

                <!-- Security Note Below -->
                <table width="600" border="0" cellspacing="0" cellpadding="0" style="margin-top: 20px;">
                    <tr>
                        <td style="text-align: center; padding: 0 20px;">
                            <p style="margin: 0; font-size: 12px; color: #aaaaaa; line-height: 1.5;">
                                Need help? Contact us at <a href="mailto:support@extalk.com"
                                    style="color: #f37e20; text-decoration: none;">support@extalk.com</a>
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>